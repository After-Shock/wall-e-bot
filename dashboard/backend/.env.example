# Discord OAuth Application
# Create at: https://discord.com/developers/applications
DISCORD_CLIENT_ID=your_discord_client_id_here
DISCORD_CLIENT_SECRET=your_discord_client_secret_here

# Bot Token (from Discord Developer Portal)
DISCORD_BOT_TOKEN=your_bot_token_here

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/walle_bot

# Redis (for rate limiting and caching)
REDIS_URL=redis://localhost:6379

# Session Secret (generate with: openssl rand -base64 32)
SESSION_SECRET=your_random_secret_key_here

# API Configuration
API_URL=http://localhost:3001
DASHBOARD_URL=http://localhost:3000

# Environment
NODE_ENV=development
PORT=3001

# 32-byte hex key for AES-256-GCM token encryption
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=your_64_char_hex_key_here

# Sentry error tracking DSN (leave blank to disable)
SENTRY_DSN=
